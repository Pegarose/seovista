{
  "name": "@seovista/web",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 3100",
    "lighthouse": "lhci autorun",
    "lint": "eslint .",
    "start": "node server.mjs",
    "test": "vitest run",
    "test:a11y": "playwright test --project=a11y",
    "test:e2e": "playwright test",
    "test:seo": "playwright test --project=seo",
    "typecheck": "tsc --noEmit"
  },
  "nextConfig": {
    "trailingSlash": true
  },
  "dependencies": {
    "next": "15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@seovista/seo-core": "workspace:*",
    "@seovista/content-models": "workspace:*",
    "@seovista/schema": "workspace:*"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "fast-xml-parser": "^5.0.0",
    "lighthouse": "^12.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
