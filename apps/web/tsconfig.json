{
  "compilerOptions": {
    "noImplicitAny": true,
    "strictNullChecks": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strict": true,
    "noEmit": true,
    "jsx": "preserve",
    "incremental": true,
    "outDir": "./.next",
    "rootDir": "./",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "exclude": ["node_modules", ".next", ".next-*"],
  "include": ["next-env.d.ts", "./**/*.ts", "./**/*.tsx", ".next-canonical/types/**/*.ts"],
  "extends": "../../tsconfig.base.json"
}
