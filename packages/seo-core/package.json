{
  "name": "@seovista/seo-core",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./env": {
      "import": "./dist/env/index.js",
      "types": "./dist/env/index.d.ts"
    },
    "./env/client": {
      "import": "./dist/env/client.js",
      "types": "./dist/env/client.d.ts"
    },
    "./env/server": {
      "import": "./dist/env/server.js",
      "types": "./dist/env/server.d.ts"
    },
    "./env/schema": {
      "import": "./dist/env/schema.js",
      "types": "./dist/env/schema.d.ts"
    },
    "./security/headers": {
      "import": "./dist/security/headers.js",
      "types": "./dist/security/headers.d.ts",
      "default": "./dist/security/headers.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "server-only": "^0.0.1",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
