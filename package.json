{
  "name": "seovista-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SeoVista Sprint 0 — AI visibility and GEO readiness platform monorepo",
  "license": "MIT",
  "author": "SeoVista Engineering",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": "10.30.1"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "pnpm run --recursive --if-present --sort --aggregate-output build",
    "typecheck": "pnpm --filter ./packages/* --if-present build && pnpm run --recursive --if-present --aggregate-output typecheck",
    "lint": "pnpm run --recursive --if-present --aggregate-output lint",
    "test": "pnpm --filter ./packages/* --if-present build && pnpm run --recursive --if-present --aggregate-output test",
    "test:e2e": "pnpm run --filter @seovista/web --if-present test:e2e",
    "test:a11y": "pnpm run --filter @seovista/web --if-present test:a11y",
    "test:seo": "pnpm run --filter @seovista/web --if-present test:seo",
    "lighthouse": "pnpm run --filter @seovista/web --if-present lighthouse"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/js-yaml": "^4.0.9",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.2.2",
    "eslint-plugin-import": "^2.31.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    }
  }
}
